# rocCLAW environment variables.
# Copy this file to `.env` and customize as needed. All values are optional
# unless noted; defaults shown below are what rocCLAW uses when the variable
# is unset.

# HTTP port for the rocCLAW server.
PORT=3000

# Bind address. Use 0.0.0.0 to expose on the LAN (then ROCCLAW_ACCESS_TOKEN
# becomes REQUIRED — the server refuses to start on a public address without it).
HOST=127.0.0.1

# Cookie-based access token. REQUIRED when binding to a non-loopback address.
# Generate one with: openssl rand -hex 32
# ROCCLAW_ACCESS_TOKEN=

# Default gateway WebSocket URL used when no saved settings exist.
NEXT_PUBLIC_GATEWAY_URL=ws://127.0.0.1:18789

# Override the base directory for all OpenClaw/rocCLAW state
# (settings.json, device.json, state.db, etc.).
# OPENCLAW_STATE_DIR=~/.openclaw

# Set to 1 to skip the native-module ABI check (better-sqlite3) on startup.
# OPENCLAW_SKIP_NATIVE_RUNTIME_VERIFY=
